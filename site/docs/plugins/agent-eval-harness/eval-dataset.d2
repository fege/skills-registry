direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

args: |md
  **/eval-dataset**

  - --config \<path\>
  - --count \<N\> (default 5)
  - --strategy \<type\>
  - --run-id \<id\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Read Context ---

read-context: |md
  **Read Context**

  - discover.py eval config
  - eval.yaml: schema,
    execution, judges
  - eval.md skill analysis
  - judge-driven reqs
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- eval-analyze fallback (external skill) ---

invoke-analyze: |md
  **/eval-analyze**
  external skill

  - no eval.yaml found
  - ask which skill
  - Skill tool invoke
  - re-read eval.yaml
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Schema Template + Assess ---

build-template: |md
  **Parse Schema +
  Assess State**

  - required files / fields
  - {field} placeholders
  - [EXTERNAL] markers
  - ls existing cases
  - recommend --count
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Strategy Selection (decision) ---

choose: |md
  **Choose
  strategy?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.font-size: 12
}

# --- Strategy branches (LLM fan-out, primary first, stacked) ---

bootstrap: |md
  **Bootstrap (default)**
  LLM generation

  - from scratch, N cases
  - 1 simple + 1 complex
  - 1 edge case
  - rest -> judge reqs
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

expand: |md
  **Expand**
  LLM gap-filling

  - read existing cases
  - find coverage gaps
  - dedupe scenarios
  - --run-id -> failures
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

from-traces: |md
  **From-Traces**
  LLM from real inputs

  - from_traces.py
  - extract MLflow inputs
  - structure to schema
  - exit 2 -> fall back
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- External: prior run results (for expand --run-id) ---

run-results: |md
  **Prior Run**
  external data

  - state.py read
  - summary.yaml
  - judge failure
    patterns
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- External: MLflow traces ---

mlflow: |md
  **MLflow Traces**
  external service

  - production traces
  - prompt + tool I/O
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Generate / write cases ---

generate: |md
  **Generate Cases**

  - case-NNN-slug/ dirs
  - input.yaml fields
  - answers.yaml guidance
  - annotations.yaml
  - companion files
  - TODO_ for [EXTERNAL]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Validate (back-edge loop) ---

validate: |md
  **Validate**

  - read a case back
  - schema match, fields
  - {field} coverage
  - conditional judge
    both branches
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Report (output) ---

report: |md
  **Report**

  - N cases + strategy
  - coverage summary
  - TODO_ placeholders
  - next: /eval-run
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callout: case directory tree ---

case-tree: |md
  dataset/
    case-001-simple-basic/
      input.yaml
      answers.yaml
      annotations.yaml
    case-002-complex-multi/
      input.yaml
      strategy.md
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Callout: input.yaml + annotations YAML ---

yaml-snippet: |md
  # input.yaml
  prompt: "..."
  strat_key: "..."
  project_key: TODO_JIRA_PROJECT_KEY
  # annotations.yaml
  dedup_is_duplicate: true
  tags: [dedup, high-overlap]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

args -> read-context
read-context -> invoke-analyze: "no eval.yaml" {
  style.stroke-dash: 3
}
invoke-analyze -> build-template
read-context -> build-template
build-template -> choose

# Strategy fan-out (labeled selecting edges)
choose -> bootstrap: "default /\n< 5 cases"
choose -> expand: "thin coverage"
choose -> from-traces: "--strategy\nfrom-traces"

# External data feeds
expand -> run-results: "--run-id" {
  style.stroke-dash: 3
}
from-traces -> mlflow: "search" {
  style.stroke-dash: 3
}

# Converge into generation
bootstrap -> generate
expand -> generate
from-traces -> generate

# Validation loop
generate -> validate
validate -> generate: "schema errors" {
  style.stroke-dash: 3
}
validate -> report

# Callouts
generate -> case-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
generate -> yaml-snippet: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
