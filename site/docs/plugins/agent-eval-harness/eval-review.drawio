<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="entry" value="&lt;b&gt;/eval-review&lt;/b&gt;&lt;br&gt;&lt;br&gt;--run-id &lt;id&gt; (required)&lt;br&gt;--config &lt;path&gt;&lt;br&gt;--cases &lt;name ...&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="70" width="200" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="load-results" value="&lt;b&gt;Discover Config + Load Results&lt;/b&gt;&lt;br&gt;&lt;br&gt;discover.py: find eval.yaml&lt;br&gt;read skill field &#8594; eval-name&lt;br&gt;state.py read summary.yaml&lt;br&gt;read eval.yaml (schema, judges)&lt;br&gt;deterministic vs LLM judges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="320" y="70" width="250" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="overview" value="&lt;b&gt;Present Overview&lt;/b&gt;&lt;br&gt;&lt;br&gt;read analysis.md if present&lt;br&gt;mention report.html link&lt;br&gt;pass rates per judge&lt;br&gt;passed-all vs failed counts&lt;br&gt;pairwise win/loss/tie&lt;br&gt;ask: all / failures / specific?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="600" y="70" width="240" height="180" as="geometry"/>
    </mxCell>
    <mxCell id="walk-cases" value="&lt;b&gt;Walk Through Cases&lt;/b&gt;&lt;br&gt;human-in-the-loop (AskUserQuestion)&lt;br&gt;&lt;br&gt;judge scores + rationale + type&lt;br&gt;pairwise winner per case&lt;br&gt;summarize output files (no dump)&lt;br&gt;ask feedback: judges miss anything?&lt;br&gt;empty feedback = acceptable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=3;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="880" y="65" width="250" height="185" as="geometry"/>
    </mxCell>
    <mxCell id="transcripts" value="&lt;b&gt;Check Transcripts&lt;/b&gt;&lt;br&gt;Agent delegation (large logs)&lt;br&gt;&lt;br&gt;read execution_mode (case/batch)&lt;br&gt;spawn Agent on stdout.log&lt;br&gt;multiple approaches? unclear?&lt;br&gt;wasted turns / roundabout paths?&lt;br&gt;report process findings to user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333333;strokeWidth=3;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;double=1;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
      <mxGeometry x="1170" y="65" width="255" height="185" as="geometry"/>
