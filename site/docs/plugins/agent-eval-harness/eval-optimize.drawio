    <mxCell id="entry" value="&lt;b&gt;/eval-optimize&lt;/b&gt;&lt;br&gt;&lt;br&gt;--config &lt;path&gt;&lt;br&gt;--model &lt;model&gt;&lt;br&gt;--max-iterations N (3)&lt;br&gt;--run-id &lt;id&gt;&lt;br&gt;--target-judge &lt;name&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;strokeWidth=2;verticalAlign=top;spacingTop=5;fontSize=11;fontFamily=Inter,Helvetica,Arial,sans-serif;arcSize=16;absoluteArcSize=1;" vertex="1" parent="1">
