direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-optimize**

  - --config \<path\>
  - --model \<model\>
  - --max-iterations N (3)
  - --run-id \<id\>
  - --target-judge \<name\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0: Config + State ---

config-state: |md
  **Discover Config + Init State**

  - discover.py find eval.yaml
  - 1 -> auto; many -> ask user
  - read skill field -> eval-name
  - state.py init optimize-config
  - model, max_iterations, run_id
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Initial eval (external skill) ---

initial-run: |md
  **/eval-run** (iter-0)
  external skill (Skill tool)

  - run full suite
  - state.py read summary.yaml
  - skip if results exist
  - all pass -> exit early
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Step 2: Identify failures ---

identify: |md
  **Identify Failures**

  - which judges failed, which cases
  - read failure rationale
  - systematic vs input-dependent
  - check review.yaml (human feedback)
  - tag judge_type per failure
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Analyze root causes (LLM/Agent) ---

analyze: |md
  **Analyze Root Causes**
  LLM agents (Explore)

  - read SKILL.md (find_skills.py)
  - trace failing cases stdout.log
  - examine failing case outputs
  - form grounded hypotheses
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Edit the skill (LLM) ---

edit-skill: |md
  **Edit the SKILL.md**
  LLM-driven targeted edits

  - ground each edit in evidence
  - surgical, minimal changes
  - explain the why, avoid overfit
  - show diff before applying
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 5: Re-run + verify (external skill) ---

rerun: |md
  **/eval-run** (iter-N)
  external skill (Skill tool)

  - --cases (targeted) or full
  - --baseline iter-(N-1)
  - --no-llm-judges (structural)
  - state.py read summary.yaml
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Regression / pass decision ---

check: |md
  **Fixed + no regressions?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Handle regressions (Step 6) ---

regress: |md
  **Handle Regression**

  - assess severity vs original
  - minor -> keep, net positive
  - major -> revert, reframe edit
  - stuck -> report, suggest review
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output: report (Step 7) ---

report-out: |md
  **Report Outcome**

  - edits -> failures fixed
  - iterations taken, final scores
  - persistent failures explained
  - next: /eval-review, /eval-mlflow
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Callouts ---

failure-map: |md
  judge (type) -> cases -> rationale

  cost_budget (builtin)
    -> [c03] over max_cost_usd
  ac_present (check)
    -> [c01,c07] no acceptance criteria
  faithful (llm)
    -> [c07] output drifts from spec
  human_review
    -> [c07] user flagged tone
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

diff-snippet: |md
  hypothesis: Step 4 says
    "optionally add acceptance criteria"
  evidence: transcript skipped Step 4

  - optionally add acceptance criteria
  + add acceptance criteria for each
  + story so reviewers can verify scope
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

guardrails: |md
  NEVER edits (eval harness = ground truth):
    builtin judges (agent_eval/judges/)
    inline check / llm prompt judges
    eval.yaml config + arguments
    test cases / datasets
  instead -> suggest changes to the user
  builtin too strict -> bump arguments:
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Forward flow ---

entry -> config-state
config-state -> initial-run
initial-run -> identify: "summary.yaml"
identify -> analyze
analyze -> edit-skill: "hypotheses"
edit-skill -> rerun: "edited SKILL.md"
rerun -> check: "new summary.yaml"

check -> report-out: "all judges pass"
check -> regress: "regressions"

# --- Back-edges (the iterative loop) ---

regress -> edit-skill: "revert / reframe" {
  style.stroke-dash: 3
}
check -> identify: "iter < max\nremaining failures" {
  style.stroke-dash: 3
}

# --- Callout connectors ---

identify -> failure-map: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
edit-skill -> diff-snippet: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
edit-skill -> guardrails: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
