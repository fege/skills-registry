direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Setup (optional, one-time) ---

eval-setup: |md
  **/eval-setup**

  configure MLflow, verify
  deps + API keys (optional)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Analyze ---

eval-analyze: |md
  **/eval-analyze**

  read skill, generate
  eval.yaml + eval.md
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Dataset ---

eval-dataset: |md
  **/eval-dataset**

  generate test cases
  matching the schema
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Run (central hub) ---

eval-run: |md
  **/eval-run**

  execute cases, score
  judges, report results
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Review (fan-out) ---

eval-review: |md
  **/eval-review**

  human-in-the-loop review,
  propose SKILL.md edits
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Optimize (fan-out) ---

eval-optimize: |md
  **/eval-optimize**

  automated fix loop, re-run
  until judges pass
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- MLflow (external service) ---

eval-mlflow: |md
  **/eval-mlflow**

  sync datasets, log runs,
  push/pull trace feedback
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Check (side-channel) ---

eval-check: |md
  **/eval-check**

  harness health check:
  overlap, redundancy
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Flow ---

eval-setup -> eval-analyze: "environment ready"
eval-analyze -> eval-dataset: "eval.yaml"
eval-dataset -> eval-run: "test cases"

eval-run -> eval-review: "summary.yaml"
eval-run -> eval-optimize: "summary.yaml"

eval-optimize -> eval-run: "re-run, SKILL.md edits" {
  style.stroke-dash: 3
}

eval-dataset -> eval-mlflow: "sync dataset" {
  style.stroke-dash: 3
}
eval-run -> eval-mlflow: "log results" {
  style.stroke-dash: 3
}
eval-review -> eval-mlflow: "push/pull feedback" {
  style.stroke-dash: 3
}

eval-run -> eval-check: "harness health" {
  style.stroke-dash: 3
}
