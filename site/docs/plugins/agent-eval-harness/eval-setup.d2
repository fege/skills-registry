direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-setup**

  - --tracking-uri <uri>
  - --skip-mlflow
  - --runs-dir <path>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 1: Dependencies ---

install-deps: |md
  **Install Dependencies**

  - isolated .eval-venv
  - re-run ensure_deps.py
  - uv / venv pip fallback
  - mlflow[genai], anthropic[vertex]
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Preflight gate ---

preflight: |md
  **Run Preflight Checks**

  check_env.py --fix
  venv / deps / dirs
  all checks pass?
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Configure MLflow tracking ---

mlflow-config: |md
  **Configure MLflow Tracking**

  - skip if --skip-mlflow
  - local server :5000
  - sqlite file store
  - remote (Databricks)
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 4: API keys ---

api-keys: |md
  **Configure API Keys**

  - ANTHROPIC_API_KEY
  - ANTHROPIC_VERTEX_PROJECT_ID
  - judges + skill execution
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 5 / 5b: Runs dir + skill env ---

runs-dir: |md
  **Configure Runs Dir + Env**

  - AGENT_EVAL_RUNS_DIR
  - default eval/runs
  - check eval.yaml $VAR refs
  - warn if any unset
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 6: Create MLflow experiment ---

create-exp: |md
  **Create MLflow Experiment**

  - read eval.yaml mlflow
  - setup_experiment()
  - resolve_tracking_uri()
  - skip if no eval.yaml
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 7: Final verification ---

verify: |md
  **Final Verification**

  - re-run check_env.py
  - validate eval.yaml
  - confirm all set up
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Output ---

report-out: |md
  **Report + Next Steps**

  - what passed / failed
  - analyze -> dataset
  - run -> review
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External dependency: MLflow server ---

mlflow-server: |md
  **MLflow Server**
  external tracking

  - experiment registry
  - traces + metrics
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callout: venv check snippet ---

venv-check: |md
  VENV=.eval-venv/bin/python3
  test -x $VENV
    -> venv: OK
  $VENV -c 'import yaml'
    -> pyyaml: OK
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Callout: MLflow setup options ---

mlflow-options: |md
  # local server (recommended)
  mlflow server --port 5000
  export MLFLOW_TRACKING_URI=
    http://127.0.0.1:5000
  # local file store
  export MLFLOW_TRACKING_URI=
    sqlite:///mlflow.db
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Callout: URI precedence ---

uri-precedence: |md
  URI resolution order:
  1. mlflow.tracking_uri
       (eval.yaml)
  2. MLFLOW_TRACKING_URI
       (env var)
  3. http://127.0.0.1:5000
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Flow ---

entry -> install-deps
install-deps -> preflight

preflight -> create-exp: "all pass"
preflight -> mlflow-config: "checks fail"

mlflow-config -> api-keys
api-keys -> runs-dir
runs-dir -> create-exp: "re-check"

create-exp -> verify
verify -> report-out

# Back-edge: final verification re-runs preflight to confirm fixes
verify -> preflight: "re-verify" {
  style.stroke-dash: 3
}

# External service connections (dashed)
mlflow-config -> mlflow-server: "connect" {
  style.stroke-dash: 3
}
create-exp -> mlflow-server: "register" {
  style.stroke-dash: 3
}

# Callout connections (light dashed)
install-deps -> venv-check: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
mlflow-config -> mlflow-options: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
mlflow-config -> uri-precedence: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
