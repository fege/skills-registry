direction: right

*.style.border-radius: 8
*.style.font-size: 13
*.style.fill: "#f5f5f5"
*.style.stroke: "#333333"

# --- Entry ---

entry: |md
  **/eval-review**

  - --run-id \<id\> (required)
  - --config \<path\>
  - --cases \<name ...\>
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 0 + 1: Discover config + load results ---

load-results: |md
  **Discover Config + Load Results**

  - discover.py: find eval.yaml
  - read skill field -> eval-name
  - state.py read summary.yaml
  - read eval.yaml (skill,
    schema, judges)
  - note deterministic vs LLM judges
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 2: Present overview ---

overview: |md
  **Present Overview**

  - read analysis.md if present
  - mention report.html link
  - pass rates per judge
  - passed-all vs failed counts
  - pairwise win/loss/tie
  - ask: all / failures / specific?
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 3: Walk cases (human-in-the-loop) ---

walk-cases: |md
  **Walk Through Cases**
  human-in-the-loop (AskUserQuestion)

  - judge scores + rationale + type
  - pairwise winner per case
  - summarize output files (no dump)
  - ask feedback: judges miss anything?
  - empty feedback = acceptable
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 4: Check transcripts (Agent, optional) ---

transcripts: |md
  **Check Transcripts**
  Agent delegation (large logs)

  - read execution_mode (case/batch)
  - spawn Agent on stdout.log
  - multiple approaches? unclear?
  - wasted turns / roundabout paths?
  - report process findings to user
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 5: Save feedback ---

save-feedback: |md
  **Save Feedback**

  - Write review.yaml (NOT state.py)
  - reviewer: human
  - keys = case dir names
  - empty value = acceptable
  - read by /eval-optimize + /eval-mlflow
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 6: Analyze patterns (LLM) ---

analyze: |md
  **Analyze Patterns**
  read review-results.md framework

  - judge-human alignment
  - systematic vs edge-case issues
  - candidate new judges
  - present "what I noticed..."
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Step 7: Propose changes (approval-gated, LLM) ---

propose: |md
  **Propose Changes**
  approval-gated edits (LLM)

  - find_skills.py locate SKILL.md
  - map complaints to instructions
  - show before/after diff per edit
  - propose new judges (prefer builtins)
  - require explicit approval
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.double-border: true
}

# --- Approval gate decision ---

approved: |md
  **Approved?**
| {
  shape: diamond
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- Step 8: Apply + next steps ---

next-steps: |md
  **Apply + Next Steps**

  - Edit SKILL.md / eval.yaml
  - /eval-run --baseline \<run-id\>
  - /eval-optimize (automated)
  - /eval-dataset --strategy expand
  - /eval-mlflow push-feedback
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#333333"
  style.stroke-width: 2
}

# --- External skills (dashed) ---

eval-optimize: |md
  **/eval-optimize**
  automated refinement
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

eval-mlflow: |md
  **/eval-mlflow**
  push-feedback to traces
| {
  shape: rectangle
  style.fill: "#e8e8e8"
  style.stroke: "#333333"
  style.stroke-width: 2
  style.stroke-dash: 3
}

# --- Callouts ---

runs-tree: |md
  runs/\<eval\>/\<id\>/
    summary.yaml
    analysis.md
    report.html
    run_result.json
    cases/\<case\>/
      stdout.log
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

review-yaml: |md
  run_id: "\<id\>"
  reviewed_cases: 3
  feedback_cases: 2
  reviewer: "human"
  feedback:
    case-001-...: "comment"
    case-002-...: "comment"
    case-003-...: ""
| {
  shape: rectangle
  style.fill: "#f5f5f5"
  style.stroke: "#bbbbbb"
  style.stroke-width: 1
  style.font: mono
  style.font-size: 10
}

# --- Forward flow ---

entry -> load-results
load-results -> overview
overview -> walk-cases
walk-cases -> transcripts
transcripts -> save-feedback
save-feedback -> analyze
analyze -> propose
propose -> approved
approved -> next-steps: "yes"

# --- External fan-out ---

next-steps -> eval-optimize: "automated"
next-steps -> eval-mlflow: "push feedback"

# --- Callout connectors ---

load-results -> runs-tree: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}
save-feedback -> review-yaml: {
  style.stroke: "#bbbbbb"
  style.stroke-dash: 4
  style.stroke-width: 1
}

# --- Back-edges (loops) ---

transcripts -> walk-cases: "more cases" {
  style.stroke-dash: 3
}
approved -> propose: "revise" {
  style.stroke-dash: 3
}
next-steps -> entry: "re-run + review" {
  style.stroke-dash: 3
}
